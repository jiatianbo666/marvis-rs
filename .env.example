# DeepSeek API Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen Vision API Configuration (SiliconFlow)
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=Qwen/Qwen3.5-35B-A3B
QWEN_BASE_URL=https://api.siliconflow.cn/v1/chat/completions

# Default AI provider: "deepseek" or "qwen" or "mock"
MARVIS_AI_PROVIDER=deepseek

# Permission mode: "readonly", "normal", "dangerous"
MARVIS_PERMISSION_MODE=normal
